<UserControl x:Class="Warehouse.UserControls.ProductDescriptionControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Opis Produktu" FontWeight="Bold" FontSize="16" 
                   Margin="0,0,0,10" HorizontalAlignment="Center"/>
        <Border Grid.Row="1" BorderBrush="#DDDDDD" BorderThickness="1" 
                Background="White" CornerRadius="4" Padding="10">
            <ScrollViewer VerticalScrollBarVisibility="Auto" 
                          HorizontalScrollBarVisibility="Disabled">
                <TextBox Text="{Binding SelectedProduct.Description}" 
                     TextWrapping="Wrap"
                     IsReadOnly="True"
                     BorderThickness="0"
                     Background="Transparent"
                     Cursor="IBeam"/>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
