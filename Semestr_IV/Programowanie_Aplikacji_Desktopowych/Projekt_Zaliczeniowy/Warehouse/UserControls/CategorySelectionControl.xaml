<UserControl x:Class="Warehouse.UserControls.CategorySelectionControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ComboBox ItemsSource="{Binding Categories}" 
              SelectedItem="{Binding SelectedCategory, ValidatesOnNotifyDataErrors=True, UpdateSourceTrigger=PropertyChanged}" 
              DisplayMemberPath="Name" 
              IsEditable="True" 
              IsReadOnly="True" 
              Text="-- Wybierz Kategorię --" 
              Padding="5" />
</UserControl>