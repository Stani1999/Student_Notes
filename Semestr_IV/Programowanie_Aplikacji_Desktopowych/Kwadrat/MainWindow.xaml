<Window x:Class="Kwadrat.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Kwadrat"
        mc:Ignorable="d"
        Title="MainWindow" Height="550" Width="800">
    <Grid>
        <Label Content="Informacje o kwadracie" HorizontalAlignment="Center" Margin="0,10,0,0" VerticalAlignment="Top" Width="140"/>
        <Label Content="Bok" HorizontalAlignment="Left" Margin="12,147,0,0" VerticalAlignment="Top" Width="55" Height="26"/>
        <Label Content="Obwód" HorizontalAlignment="Left" Margin="12,178,0,0" VerticalAlignment="Top" Height="26" Width="55"/>
        <Label Content="Pole" HorizontalAlignment="Left" Margin="12,208,0,0" VerticalAlignment="Top" Width="55" Height="27"/>
        <TextBox x:Name="tbBok" HorizontalAlignment="Left" Margin="87,147,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="136" TextChanged="tbBok_TextChanged" Height="26"/>
        <TextBox x:Name="tbObwod" HorizontalAlignment="Left" Margin="87,178,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="136" IsReadOnly="True" Height="26"/>
        <TextBox x:Name="tbPole" HorizontalAlignment="Left" Margin="87,209,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="136" IsReadOnly="True" Height="26"/>
        <Label x:Name="labelWorning" Content="" HorizontalAlignment="Left" Margin="240,147,0,0" VerticalAlignment="Top" Visibility="Hidden" Foreground="Red"/>
        <Button Content="Reset" HorizontalAlignment="Left" Margin="87,361,0,0" VerticalAlignment="Top" Height="26" Width="136" Click="Button_Click"/>
        <CheckBox x:Name="cbPrzezroczystosc" Content="Przezroczystość" HorizontalAlignment="Left" Margin="87,272,0,0" VerticalAlignment="Top" Checked="CheckBox_Checked" Unchecked="CheckBox_Checked" Height="22" Width="136"/>
        <Button x:Name="btnRysuj" Content="Rysuj" HorizontalAlignment="Left" Margin="87,330,0,0" VerticalAlignment="Top" Width="136" Height="26" Click="btnRysuj_Click"/>
        <Label Content="Kolor" HorizontalAlignment="Left" Margin="12,240,0,0" VerticalAlignment="Top" RenderTransformOrigin="2.006,-1.016" Width="55"/>
        <Slider x:Name="sliderPrzezroczystosc" HorizontalAlignment="Left" Margin="87,299,0,0" VerticalAlignment="Top" Width="136" Height="26" Minimum="0" Maximum="1" Value="1" SmallChange="0.2" TickFrequency="0.2" IsSnapToTickEnabled="True" ValueChanged="sliderPrzezroczystosc_ValueChanged"/>
        <ComboBox x:Name="cbKolor" HorizontalAlignment="Left" Margin="87,240,0,0" VerticalAlignment="Top" Width="136" Height="27" SelectionChanged="ComboBox_SelectionChanged">
            <ComboBoxItem Content="Red" IsSelected="True"/>
            <ComboBoxItem Content="Green" />
            <ComboBoxItem Content="Blue" />
        </ComboBox>

        <Canvas HorizontalAlignment="Left" Height="300" Margin="350,147,0,0" VerticalAlignment="Top" Width="300">
            <Rectangle x:Name="rectKwadrat" Fill="Red" Height="0" Width="0"/>
        </Canvas>
        <Label Content="Widać" HorizontalAlignment="Left" Margin="245,294,0,0" VerticalAlignment="Top" RenderTransformOrigin="2.006,-1.016" Width="56"/>
        <Label Content="Nie widać" HorizontalAlignment="Left" Margin="12,294,0,0" VerticalAlignment="Top" RenderTransformOrigin="2.006,-1.016" Width="70"/>
    </Grid>
</Window>