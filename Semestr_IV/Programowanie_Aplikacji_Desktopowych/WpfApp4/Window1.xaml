<Window x:Class="WpfApp4.Window1"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp4"
        mc:Ignorable="d"
        Title="Edycja" Height="250" Width="350">
    <Grid x:Name="GEdycja">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        
        <Label Content="Indeks" Grid.Row="0" Grid.Column="0" Margin="7" />
        <TextBox Grid.Row="0" Grid.Column="1" Margin="7" Text="{Binding indeks}" />
        
        <Label Content="Nazwa" Grid.Row="1" Grid.Column="0" Margin="7" />
        <TextBox Grid.Row="1" Grid.Column="1" Margin="7" Text="{Binding nazwa}" />
        
        <Label Content="Ilość" Grid.Row="2" Grid.Column="0" Margin="7" />
        <TextBox Grid.Row="2" Grid.Column="1" Margin="7" Text="{Binding ilosc}" />
        
        <Label Content="Miasto" Grid.Row="3" Grid.Column="0" Margin="7" />
        <TextBox Grid.Row="3" Grid.Column="1" Margin="7" Text="{Binding miasto}" />

        <Button x:Name="Zapisz" Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Margin="7" MinWidth="150" HorizontalAlignment="Center" Content="Aktualizuj" Click="Zapisz_Click"  />
    </Grid>
</Window>
