<Window x:Class="Sztuczne_Sieci_Neuronowe.Src.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Dobór technologii dla zespołu" Height="650" Width="500" Background="#F0F0F0" MinHeight="620" MinWidth="450">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
        <StackPanel Margin="20">

            <TextBlock FontWeight="Bold" Margin="0,0,0,5">
                <Run Text="Platforma docelowa (Android: "/>
                <Run x:Name="R_Android_Pts" Text="5"/>
                <Run Text=" | iOS: "/>
                <Run x:Name="R_iOS_Pts" Text="5"/>
                <Run Text=")"/>
            </TextBlock>
            <Grid Margin="0,0,0,15">
                <TextBlock Text="Android" HorizontalAlignment="Left" Foreground="Green" FontWeight="Bold"/>
                <TextBlock Text="iOS" HorizontalAlignment="Right" Foreground="Blue" FontWeight="Bold"/>
                <Slider x:Name="S_Platform" Minimum="-5" Maximum="5" Value="0" Margin="60,0,60,0"
                        TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="S_Platform_ValueChanged"/>
            </Grid>

            <Separator Margin="0,10"/>

            <TextBlock Margin="0,10,0,0">
                <Run Text="Wydajność: "/>
                <Run x:Name="L_Perf_Desc" Text="Średnia" FontWeight="Bold"/>
                <Run Text=" ("/>
                <Run Text="{Binding ElementName=S_Performance, Path=Value}"/>
                <Run Text=")"/>
            </TextBlock>
            <Slider x:Name="S_Performance" Maximum="10" Value="5" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="Slider_ValueChanged"/>

            <TextBlock Margin="0,10,0,0">
                <Run Text="Zaawansowanie UI: "/>
                <Run x:Name="L_UI_Desc" Text="Średnie" FontWeight="Bold"/>
                <Run Text=" ("/>
                <Run Text="{Binding ElementName=S_UI, Path=Value}"/>
                <Run Text=")"/>
            </TextBlock>
            <Slider x:Name="S_UI" Maximum="10" Value="5" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="Slider_ValueChanged"/>

            <TextBlock Margin="0,10,0,0">
                <Run Text="Wsparcie Hardware: "/>
                <Run x:Name="L_Hard_Desc" Text="Średnie" FontWeight="Bold"/>
                <Run Text=" ("/>
                <Run Text="{Binding ElementName=S_Hardware, Path=Value}"/>
                <Run Text=")"/>
            </TextBlock>
            <Slider x:Name="S_Hardware" Maximum="10" Value="5" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="Slider_ValueChanged"/>

            <TextBlock Margin="0,10,0,0">
                <Run Text="Funkcjonalność (Logika): "/>
                <Run x:Name="L_Func_Desc" Text="Średnia" FontWeight="Bold"/>
                <Run Text=" ("/>
                <Run Text="{Binding ElementName=S_Func, Path=Value}"/>
                <Run Text=")"/>
            </TextBlock>
            <Slider x:Name="S_Func" Maximum="10" Value="5" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="Slider_ValueChanged"/>

            <TextBlock Margin="0,10,0,0">
                <Run Text="Budżet: "/>
                <Run x:Name="L_Budget_Desc" Text="Średni" FontWeight="Bold"/>
                <Run Text=" ("/>
                <Run Text="{Binding ElementName=S_Budget, Path=Value}"/>
                <Run Text=")"/>
            </TextBlock>
            <Slider x:Name="S_Budget" Maximum="10" Value="5" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="Slider_ValueChanged"/>

            <TextBlock Margin="0,10,0,0">
                <Run Text="Próg wejścia / Nauka: "/>
                <Run x:Name="L_Learning_Desc" Text="Średni" FontWeight="Bold"/>
                <Run Text=" ("/>
                <Run Text="{Binding ElementName=S_Learning, Path=Value}"/>
                <Run Text=")"/>
            </TextBlock>
            <Slider x:Name="S_Learning" Maximum="10" Value="5" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="Slider_ValueChanged"/>

            <TextBlock Margin="0,10,0,0">
                <Run Text="Czas realizacji (Deadline): "/>
                <Run x:Name="L_Deadline_Desc" Text="Średni" FontWeight="Bold"/>
                <Run Text=" ("/>
                <Run Text="{Binding ElementName=S_Deadline, Path=Value}"/>
                <Run Text=")"/>
            </TextBlock>
            <Slider x:Name="S_Deadline" Maximum="10" Value="5" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="Slider_ValueChanged"/>

            <Button x:Name="B_Analyze" Content="Analizuj technologię" Margin="0,20,0,0" Height="40" FontWeight="Bold" Background="#DDD" Click="B_Analyze_Click"/>
            <Button x:Name="B_Details" Content="Pełny Ranking"  Height="40" Margin="0,10,0,0" FontWeight="Bold" Background="#DDD" Click="B_Details_Click"/>
            <Label x:Name="L_Test" Content="Status: Gotowy" Margin="0,10,0,0"/>
        </StackPanel>
    </ScrollViewer>
</Window>