<Window x:Class="Kwadratury.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:Kwadratury.UserControls"
        Title="Kwadratury - Całkowanie Numeryczne" Height="800" Width="1200"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="350"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Margin="0,0,10,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <controls:IntegrationParametersControl Grid.Row="0" Margin="0,0,0,10"/>
            <controls:MethodResultsControl Grid.Row="1"/>
        </Grid>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="3*"/>
                <RowDefinition Height="2*"/>
            </Grid.RowDefinitions>

            <controls:QuadraturePlotControl Grid.Row="0" Margin="0,0,0,10"/>
            <controls:QuadratureStepsControl Grid.Row="1"/>
        </Grid>
    </Grid>
</Window>