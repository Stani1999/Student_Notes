<UserControl x:Class="Kwadratury.UserControls.IntegrationParametersControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Border Background="#F9F9F9" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="5" Padding="15">
        <StackPanel>
            <TextBlock Text="Ustawienia Całkowania" FontWeight="Bold" FontSize="16" Margin="0,0,0,15" Foreground="#333"/>

            <TextBlock Text="Funkcja f(x):" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <TextBox x:Name="tbFunc" Text="{Binding Parameters.FunctionExpression, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}" Padding="5" FontSize="14"/>
            <ItemsControl ItemsSource="{Binding (Validation.Errors), ElementName=tbFunc}" Margin="0,2,0,10">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding ErrorContent}" Foreground="#D13438" FontSize="11" TextWrapping="Wrap"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Początek (a):" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBox x:Name="tbA" Text="{Binding Parameters.A, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}" Padding="5"/>
                    <ItemsControl ItemsSource="{Binding (Validation.Errors), ElementName=tbA}" Margin="0,2,0,10">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding ErrorContent}" Foreground="#D13438" FontSize="11" TextWrapping="Wrap"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Koniec (b):" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBox x:Name="tbB" Text="{Binding Parameters.B, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}" Padding="5"/>
                    <ItemsControl ItemsSource="{Binding (Validation.Errors), ElementName=tbB}" Margin="0,2,0,10">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding ErrorContent}" Foreground="#D13438" FontSize="11" TextWrapping="Wrap"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Grid>

            <StackPanel>
                <TextBlock Text="Liczba podziałów (n):" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox x:Name="tbN" Text="{Binding Parameters.N, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}" Padding="5">
                    <TextBox.Style>
                        <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ShowSimpsonWarning}" Value="True">
                                    <Setter Property="BorderBrush" Value="#E0A800"/>
                                    <Setter Property="BorderThickness" Value="2"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>
                <ItemsControl ItemsSource="{Binding (Validation.Errors), ElementName=tbN}" Margin="0,2,0,0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding ErrorContent}" Foreground="#D13438" FontSize="11" TextWrapping="Wrap"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <TextBlock Text="{Binding SimpsonWarningMessage}"
                           Foreground="#E0A800" FontSize="11" Margin="0,2,0,10" TextWrapping="Wrap"
                           Visibility="{Binding ShowSimpsonWarning, Converter={StaticResource BoolToVis}}"/>
            </StackPanel>

            <TextBlock Text="Metoda Kwadratury:" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <ComboBox ItemsSource="{Binding AvailableMethods}" 
                      SelectedItem="{Binding Parameters.SelectedMethod, UpdateSourceTrigger=PropertyChanged}" 
                      Padding="5" Margin="0,0,0,25"/>

            <Button Content="Oblicz Całkę" Command="{Binding CalculateCommand}" 
                    Padding="10" Background="#0078D7" Foreground="White" FontWeight="Bold" FontSize="14" BorderThickness="0"/>
        </StackPanel>
    </Border>
</UserControl>