<UserControl x:Class="Kwadratury.UserControls.QuadratureStepsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{Binding CalculatedMethod, StringFormat='Szczegóły kroków: {0}'}" 
                   FontWeight="Bold" FontSize="14" Margin="0,0,0,10" Foreground="#333"/>

        <DataGrid Grid.Row="1" ItemsSource="{Binding Steps}" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" AlternatingRowBackground="#F0F0F0">
            <DataGrid.Columns>
                <DataGridTextColumn Header="i" Binding="{Binding StepIndex}" Width="50"/>
                <DataGridTextColumn Header="x_i" Binding="{Binding X, StringFormat=F4}" Width="*"/>
                <DataGridTextColumn Header="y_i" Binding="{Binding Y, StringFormat=F4}" Width="*"/>
                <DataGridTextColumn Header="x_śr" Binding="{Binding X_Mid, StringFormat=F4}" Width="*"/>
                <DataGridTextColumn Header="y_śr" Binding="{Binding Y_Mid, StringFormat=F4}" Width="*"/>
                <DataGridTextColumn Header="Obliczenia" Binding="{Binding StepDetails}" Width="1.5*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>