<UserControl x:Class="Kwadratury.UserControls.MethodResultsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="#F9F9F9" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="5" Padding="10">
        <StackPanel>
            <TextBlock Text="Wyniki wszystkich metod" FontWeight="Bold" FontSize="14" Margin="0,0,0,10" Foreground="#333"/>
            <DataGrid ItemsSource="{Binding MethodResults}" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" AlternatingRowBackground="#F0F0F0" HeadersVisibility="Column">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Metoda" Binding="{Binding MethodName}" Width="*"/>
                    <DataGridTextColumn Header="n" Binding="{Binding N}" Width="30"/>
                    <DataGridTextColumn Header="Wynik" Binding="{Binding Result, StringFormat=F4}" Width="75"/>
                </DataGrid.Columns>
            </DataGrid>
        </StackPanel>
    </Border>
</UserControl>