<UserControl x:Class="Schemat_Hornera.UserControls.CoefficientInputControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ItemsControl ItemsSource="{Binding CoefficientsList}">
        <ItemsControl.ItemTemplate>
            <DataTemplate>
                <Grid Margin="0,5,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="80"/>
                    </Grid.ColumnDefinitions>

                    <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}" Padding="6"/>
                    <TextBlock Grid.Column="1"  Text="{Binding Label}" VerticalAlignment="Top" Margin="3,4,0,0" FontWeight="SemiBold" HorizontalAlignment="Left"/>
                </Grid>
            </DataTemplate>
        </ItemsControl.ItemTemplate>
    </ItemsControl>
</UserControl>