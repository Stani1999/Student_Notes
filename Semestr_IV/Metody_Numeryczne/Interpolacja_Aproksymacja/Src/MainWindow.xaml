<Window x:Class="Interpolacja_Aproksymacja.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:Interpolacja_Aproksymacja.Views"
        xmlns:oxy="http://oxyplot.org/wpf"
        Title="Analiza Numeryczna" Height="750" Width="1200">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#F4F4F4" Padding="15" BorderBrush="#CCCCCC" BorderThickness="0,0,1,0">
            <StackPanel>
                <TextBlock Text="KONFIGURACJA" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>

                <views:ImportData Margin="0,0,0,10"/>
                <views:MethodsControl Margin="0,0,0,10"/>
                <views:ParametersControl Margin="0,0,0,10"/>

                <Button Content="OBLICZ I GENERUJ" 
                        Command="{Binding CalculateCommand}" 
                        Height="50" Background="#007ACC" Foreground="White" FontWeight="Bold" Margin="0,10" Click="Button_Click"/>
            </StackPanel>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="2*"/>
                <RowDefinition Height="1*"/>
            </Grid.RowDefinitions>
            <oxy:PlotView Model="{Binding PlotModel}" Grid.Row="0" Margin="10"/>
            <DataGrid ItemsSource="{Binding InputPoints}" Grid.Row="1" Margin="10" AutoGenerateColumns="True" IsReadOnly="True"/>
        </Grid>
    </Grid>
</Window>