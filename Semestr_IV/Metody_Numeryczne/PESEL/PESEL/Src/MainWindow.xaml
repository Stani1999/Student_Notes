<Window x:Class="PESEL.Src.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding CurrentLanguage.UI.MainWindowTitle}" 
        Height="500" Width="450" MinHeight="550" MinWidth="430"
        Background="#F5F5F5">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="{Binding CurrentLanguage.UI.txtWelcome}" 
                   FontSize="18" FontWeight="Bold" Margin="0,0,0,20" 
                   HorizontalAlignment="Center" Foreground="#333"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
            <TextBlock Text="{Binding CurrentLanguage.UI.txtInputPESEL}" 
                       VerticalAlignment="Center" Margin="0,0,10,0"/>
            <TextBox x:Name="tbxPesel" Width="150" FontSize="14" 
                     VerticalContentAlignment="Center" MaxLength="11"/>
            <Button x:Name="btnCheck" Content="{Binding CurrentLanguage.UI.btnCheck}" 
                    Margin="10,0,0,0" Padding="10,5" Click="btnCheck_Click"
                    Background="#007ACC" Foreground="White" FontWeight="Bold"/>
        </StackPanel>

        <TextBlock Text="{Binding CurrentLanguage.UI.txtResult}" 
                   Grid.Row="2" FontSize="14" FontWeight="Bold" 
                   Margin="0,10,0,10" Foreground="#555"/>

        <Grid Grid.Row="3" Margin="10,0,10,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="35"/>
                <RowDefinition Height="35"/>
                <RowDefinition Height="35"/>
                <RowDefinition Height="35"/>
                <RowDefinition Height="35"/>
                <RowDefinition Height="35"/>
                <RowDefinition Height="35"/>
                <RowDefinition Height="35"/>
            </Grid.RowDefinitions>

            <TextBlock Text="{Binding CurrentLanguage.UI.txtChecksum}" Grid.Row="0" VerticalAlignment="Center"/>
            <TextBox Grid.Column="1" Grid.Row="0" Margin="10,4" IsReadOnly="True" x:Name="outChecksum"
                     Background="#EBEBEB"/>

            <TextBlock Text="{Binding CurrentLanguage.UI.txtYear}" Grid.Row="1" VerticalAlignment="Center"/>
            <TextBox Grid.Column="1" Grid.Row="1" Margin="10,4" IsReadOnly="True" x:Name="outYear"
                     Background="#EBEBEB"/>

            <TextBlock Text="{Binding CurrentLanguage.UI.txtMonth}" Grid.Row="2" VerticalAlignment="Center"/>
            <TextBox Grid.Column="1" Grid.Row="2" Margin="10,4" IsReadOnly="True" x:Name="outMonth"
                     Background="#EBEBEB"/>

            <TextBlock Text="{Binding CurrentLanguage.UI.txtDay}" Grid.Row="3" VerticalAlignment="Center"/>
            <TextBox Grid.Column="1" Grid.Row="3" Margin="10,4" IsReadOnly="True" x:Name="outDay" Background="#EBEBEB"/>
            
            <TextBlock Text="{Binding CurrentLanguage.UI.txtMonthNumber}" Grid.Row="4" VerticalAlignment="Center"/>
            <TextBox Grid.Column="1" Grid.Row="4" Margin="10,4" IsReadOnly="True" x:Name="outMonthNumber" Background="#EBEBEB"/>

            <TextBlock Text="{Binding CurrentLanguage.UI.txtBirthday}" Grid.Row="5" VerticalAlignment="Center"/>
            <TextBox Grid.Column="1" Grid.Row="5" Margin="10,4" IsReadOnly="True" x:Name="outFullDate" Background="#EBEBEB"/>

            <TextBlock Text="{Binding CurrentLanguage.UI.txtGender}" Grid.Row="6" VerticalAlignment="Center"/>
            <TextBox Grid.Column="1" Grid.Row="6" Margin="10,4" IsReadOnly="True" x:Name="outGender" Background="#EBEBEB"/>

            <TextBlock Text="{Binding CurrentLanguage.UI.txtGenderShort}" Grid.Row="7" VerticalAlignment="Center"/>
            <TextBox Grid.Column="1" Grid.Row="7" Margin="10,4" IsReadOnly="True" x:Name="outGenderS" Background="#EBEBEB"/>
        </Grid>
        

        <Button x:Name="btnLang" Grid.Row="4" 
        Content="{Binding CurrentLanguage.UI.btnLanguage}" 
        HorizontalAlignment="Right" Padding="10,2" 
        FontSize="10" Click="btnLanguage_Click" Margin="20"/>
    </Grid>
</Window>