<UserControl x:Class="AproksymacjaMNK.Views.Controls.ImportData"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             mc:Ignorable="d" xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DesignWidth="300">
    <GroupBox Header="1. Dane Wejściowe" Padding="10" Margin="5">
        <StackPanel>
            <DockPanel Margin="0,0,0,10">
                <TextBlock Text="Komórka startowa:" VerticalAlignment="Center"/>
                <TextBox Text="{Binding ImportStartAddress, UpdateSourceTrigger=PropertyChanged}" 
                         Width="50" HorizontalAlignment="Right" TextAlignment="Center"/>
            </DockPanel>
            <Button Content="Wczytaj z Excel (.xlsx)" 
                    Command="{Binding ImportDataCommand}" 
                    Height="30" Cursor="Hand"/>
        </StackPanel>
    </GroupBox>
</UserControl>