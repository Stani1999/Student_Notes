<UserControl x:Class="AproksymacjaMNK.Views.Controls.ParametersControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             mc:Ignorable="d" xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DesignWidth="300">
    <GroupBox Header="3. Parametry" Padding="10" Margin="5">
        <StackPanel>
            <DockPanel Margin="0,0,0,5">
                <TextBlock Text="Stopień wielomianu (m):"/>
                <TextBlock Text="1" HorizontalAlignment="Right" FontWeight="Bold"/>
            </DockPanel>
            <Separator Margin="0,5"/>
            <DockPanel>
                <TextBlock Text="Wczytane punkty (n):"/>
                <TextBlock Text="{Binding InputPoints.Count}" HorizontalAlignment="Right" FontWeight="Bold" Foreground="Blue"/>
            </DockPanel>
        </StackPanel>
    </GroupBox>
</UserControl>