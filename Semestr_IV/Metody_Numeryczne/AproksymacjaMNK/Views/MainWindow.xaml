<Window x:Class="AproksymacjaMNK.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:AproksymacjaMNK.Views.Controls"
        xmlns:oxy="http://oxyplot.org/wpf"
        Title="System Aproksymacji MNK" Height="700" Width="1100" WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Background="#F0F0F0">
            <TextBlock Text="PANEL KONTROLNY" Margin="10,20,10,10" FontWeight="Bold" HorizontalAlignment="Center" FontSize="16"/>

            <views:ImportData/>
            <views:MethodsControl/>
            <views:ParametersControl/>

            <Button Content="OBLICZ I RYSUJ" 
                    Command="{Binding CalculateCommand}" 
                    Margin="15,20" Height="50" 
                    Background="#0078D7" Foreground="White" FontWeight="Bold"/>
        </StackPanel>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="2*"/>
                <RowDefinition Height="1*"/>
            </Grid.RowDefinitions>

            <oxy:PlotView Model="{Binding PlotModel}" Grid.Row="0" Margin="10"/>

            <GroupBox Header="Podgląd danych (Tabela)" Grid.Row="1" Margin="10">
                <DataGrid ItemsSource="{Binding InputPoints}" AutoGenerateColumns="True" IsReadOnly="True" GridLinesVisibility="Horizontal"/>
            </GroupBox>
        </Grid>
    </Grid>
</Window>