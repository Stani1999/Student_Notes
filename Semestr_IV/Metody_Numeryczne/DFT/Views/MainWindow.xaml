<Window x:Class="DFT.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:DFT.UserControls"
        Title="Analiza Fouriera DFT" Height="750" Width="1400"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                    <Button x:Name="BtnSelectFile" Content="Wybierz plik Excel" Command="{Binding BrowseFileCommand}" Padding="15,6">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="BorderBrush" Value="#ABADB3"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ElementName=TxtFilePath, Path=(Validation.HasError)}" Value="True">
                                        <Setter Property="BorderBrush" Value="Red"/>
                                        <Setter Property="BorderThickness" Value="2"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Grid Height="35" Margin="0,2,0,0">
                        <TextBlock Text="{Binding ElementName=TxtFilePath, Path=(Validation.Errors)[0].ErrorContent}" 
                                   Foreground="Red" FontWeight="Bold" FontSize="11" Margin="2,2,0,5" TextWrapping="Wrap" MaxWidth="150" HorizontalAlignment="Center" TextAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ElementName=TxtFilePath, Path=(Validation.HasError)}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <TextBlock Text="Dane zmienione. Kliknij 'Analiza Danych'." 
                                   Foreground="#107C10" FontWeight="SemiBold" FontSize="11" TextWrapping="Wrap" MaxWidth="150" HorizontalAlignment="Center" TextAlignment="Center"
                                   Visibility="{Binding IsSettingsChangedInfoVisible, Converter={StaticResource BoolToVis}}"/>
                    </Grid>
                </StackPanel>

                <Grid Grid.Column="1" VerticalAlignment="Top">
                    <TextBox x:Name="TxtFilePath" Text="{Binding ExcelFilePath, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"
                             IsReadOnly="True" Padding="6" Background="#F0F0F0" VerticalContentAlignment="Center" BorderBrush="#ABADB3">
                        <Validation.ErrorTemplate>
                            <ControlTemplate>
                                <Border BorderBrush="Red" BorderThickness="2" CornerRadius="2">
                                    <AdornedElementPlaceholder />
                                </Border>
                            </ControlTemplate>
                        </Validation.ErrorTemplate>
                    </TextBox>

                    <TextBlock Text="Najpierw wybierz plik..." Foreground="#888888" VerticalAlignment="Center" Margin="8,0,0,0" IsHitTestVisible="False">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=TxtFilePath}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </Grid>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Top" Margin="0,-15,0,0">
                <TextBlock Text="Indeks arkusza:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <TextBox Text="{Binding SheetIndex, ValidatesOnNotifyDataErrors=True}" Width="40" Margin="0,0,15,0" VerticalContentAlignment="Center" Padding="4"/>

                <TextBlock Text="Komórka startowa:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <TextBox Text="{Binding StartCell, ValidatesOnNotifyDataErrors=True}" Width="50" Margin="0,0,15,0" VerticalContentAlignment="Center" Padding="4"/>

                <TextBlock Text="Próg szumu:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <TextBox Text="{Binding NoiseThreshold, ValidatesOnNotifyDataErrors=True}" Width="50" Margin="0,0,15,0" VerticalContentAlignment="Center" Padding="4"/>

                <Button Content="Analiza Danych" Command="{Binding AnalyzeDataCommand}" Padding="15,5" Background="#0078D7" Foreground="White" BorderThickness="0" FontWeight="Bold"/>
            </StackPanel>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <controls:CombinedTablesControl Grid.Column="0" Margin="0,0,15,0" MinWidth="650"/>
            <controls:SpectrumPlotControl Grid.Column="1"/>
        </Grid>
    </Grid>
</Window>