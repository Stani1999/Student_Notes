<UserControl x:Class="DFT.UserControls.DenoisedSignalDataControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DataGrid ItemsSource="{Binding DenoisedSignals}" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" 
              ScrollViewer.VerticalScrollBarVisibility="Visible" BorderThickness="0,1,1,1" MaxWidth="420">
        <DataGrid.Columns>
            <DataGridTextColumn Header="Odszumione widmo" Binding="{Binding FilteredDftMagnitude, StringFormat=F4}" MaxWidth="130"/>
            <DataGridTextColumn Header="IDFT" Binding="{Binding IdftValue, StringFormat=F4}" MaxWidth="160"/>
            <DataGridTextColumn Header="y(n) odszumiony" Binding="{Binding DenoisedY, StringFormat=F4}" MaxWidth="130"/>
        </DataGrid.Columns>
    </DataGrid>
</UserControl>