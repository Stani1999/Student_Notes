<UserControl x:Class="DFT.UserControls.SpectrumPlotControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:oxy="http://oxyplot.org/wpf">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5,0,0">
            <StackPanel.Style>
                <Style TargetType="StackPanel">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding NoisySignals.Count}" Value="0">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </StackPanel.Style>
            <TextBlock Text="Sygnał " FontWeight="Bold" FontSize="15" Foreground="#333333"/>
            <TextBlock Text="x(n) [Wejście]" Foreground="Orange" FontWeight="Bold" FontSize="15"/>
            <TextBlock Text="  vs  Sygnał " FontWeight="Bold" FontSize="15" Foreground="#333333"/>
            <TextBlock Text="y(n) [Wyjście]" Foreground="Green" FontWeight="Bold" FontSize="15"/>
        </StackPanel>

        <oxy:PlotView Model="{Binding Plots.ComparisonPlot}" Grid.Row="1" Margin="5"/>

        <oxy:PlotView Model="{Binding Plots.SpectrumPlot}" Grid.Row="2" Margin="5"/>
    </Grid>
</UserControl>